{% assign announcement_text = shop.metafields.my_app.announcement.value %}

{%- if announcement_text != blank -%}
<div class="fa-announcement-banner">
  <div class="fa-announcement-content">
    <span>{{ announcement_text }}</span>
  </div>
</div>
{%- endif -%}

<style>
  .fa-announcement-banner {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 999999;
    background-color: #000000;
    color: #ffffff;
    padding: 14px 28px;
    border-radius: 50px; /* Modern round capsule shape */
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    animation: fa-fade-in 0.5s ease-out;
  }

  @keyframes fa-fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

{% schema %}
{
  "name": "Floating Announcement",
  "target": "body",
  "settings": []
}
{% endschema %}